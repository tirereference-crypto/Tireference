---
import { CONTACT_EMAIL } from '../../lib/info-pages';

interface Props {
  reasons?: ReadonlyArray<{ title: string; description: string }>;
  initialSubject?: string;
  initialMessage?: string;
}

const { initialSubject = '', initialMessage = '' } = Astro.props;
---

<form class="info-form" id="contact-form" novalidate>
  <div class="info-form__field">
    <label class="info-form__label" for="contact-name">Name</label>
    <input
      class="info-form__input"
      type="text"
      id="contact-name"
      name="name"
      autocomplete="name"
      required
    />
  </div>

  <div class="info-form__field">
    <label class="info-form__label" for="contact-email">Email</label>
    <input
      class="info-form__input"
      type="email"
      id="contact-email"
      name="email"
      autocomplete="email"
      required
    />
  </div>

  <div class="info-form__field">
    <label class="info-form__label" for="contact-subject">Subject</label>
    <input
      class="info-form__input"
      type="text"
      id="contact-subject"
      name="subject"
      value={initialSubject}
      required
    />
  </div>

  <div class="info-form__field">
    <label class="info-form__label" for="contact-message">Message</label>
    <textarea
      class="info-form__textarea"
      id="contact-message"
      name="message"
      required
    >{initialMessage}</textarea>
  </div>

  <button type="submit" class="tl-btn-primary info-form__submit">
    Open email to send message
  </button>

  <p class="info-form__status" id="contact-form-status" role="status" aria-live="polite" hidden>
    Your email client should open with a message to {CONTACT_EMAIL}. Send it to complete contact.
  </p>

  <p class="info-form__privacy">
    Contact details are used only to respond to your message. See our{' '}
    <a href="/privacy-policy/">Privacy Policy</a>. Preferred corrections flow:{' '}
    <a href="/report-an-issue/">Report an Issue</a>.
  </p>
</form>

<script define:vars={{ contactEmail: CONTACT_EMAIL }}>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('contact-form-status');

    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const data = new FormData(form);
      const subject = String(data.get('subject') || 'Tire Reference contact');
      const body = [
        `From: ${data.get('name')} <${data.get('email')}>`,
        '',
        String(data.get('message') || ''),
      ].join('\n');
      const params = new URLSearchParams({ subject, body });
      window.location.href = `mailto:${contactEmail}?${params.toString()}`;
      if (status) status.hidden = false;
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
