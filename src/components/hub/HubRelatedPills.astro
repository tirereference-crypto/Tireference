---
import type { RelatedSizeLink } from '../../lib/tire-size-hub';

interface Props {
  links: RelatedSizeLink[];
  emptyMessage: string;
}

const { links, emptyMessage } = Astro.props;
---

{
  links.length > 0 ? (
    <div class="flex flex-wrap gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          class="inline-flex flex-col rounded-xl border border-border bg-surface px-4 py-3 shadow-card transition-colors hover:border-primary/40 hover:bg-primary-light/30"
        >
          <span class="font-mono text-sm font-bold text-heading">{link.size}</span>
          <span class="mt-0.5 text-xs tabular-nums text-muted">
            {link.diameterIn.toFixed(1)} in
            <span class={`ml-1 font-semibold ${link.diameterDiffPercent >= 0 ? 'text-success' : 'text-danger'}`}>
              ({link.diameterDiffPercent >= 0 ? '+' : ''}{link.diameterDiffPercent.toFixed(1)}%)
            </span>
          </span>
        </a>
      ))}
    </div>
  ) : (
    <p class="text-sm text-muted">{emptyMessage}</p>
  )
}
