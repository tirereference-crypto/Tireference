---
import type { TireCategory } from '../../data/tire-sizes';

interface Props {
  category: TireCategory;
  label: string;
}

const { category, label } = Astro.props;

const categoryStyles: Record<TireCategory, string> = {
  passenger: 'border-slate-200 bg-slate-100 text-slate-700',
  performance: 'border-primary/20 bg-primary-light text-primary',
  SUV: 'border-info/20 bg-info/10 text-info',
  'light-truck': 'border-accent/20 bg-accent/10 text-accent',
  'off-road': 'border-success/20 bg-success/10 text-success',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full border px-3 py-0.5 text-[11px] font-bold uppercase tracking-wider',
    categoryStyles[category],
  ]}
>
  {label}
</span>
