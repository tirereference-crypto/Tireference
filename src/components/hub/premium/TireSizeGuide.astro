---
/**
 * Authoritative premium guide layout for every /tire-size/[size]/ page.
 */
import HubBreadcrumb from '../HubBreadcrumb.astro';
import Premium275Hero from './Premium275Hero.astro';
import ProductSpecComparison from './ProductSpecComparison';
import HubAvailableTires from './HubAvailableTires';
import HubIcon from '../HubIcon.astro';
import LastUpdated from '../../trust/LastUpdated.astro';
import type { TireSizeHubData } from '../../../lib/tire-size-hub';
import {
  buildTireSizeGuideData,
  formatTireModelDisplayName,
} from '../../../lib/tire-size-guide';
import { canonicalProductBrand, tireProductToVerifiedModel } from '../../../lib/tire-product-display';
import {
  CALCULATOR_PATHS,
  SITE_CALCULATORS,
} from '../../../lib/calculator-links';
import type { HubIconName } from '../../../lib/hub-icons';
import {
  TIRE_CATEGORY_HUBS,
  getPrimaryTireSizeHubCategory,
  getTireSizeHubCategories,
  tireCategoryHubPath,
} from '../../../lib/tire-category-hubs';
import {
  SITE_CONTENT_UPDATED,
  formatEditorialDate,
  METHODOLOGY,
  DATA_SOURCES,
} from '../../../lib/editorial';

interface Props {
  hub: TireSizeHubData;
}

const { hub } = Astro.props;
const { displaySize, specs } = hub;
const guide = buildTireSizeGuideData(hub);
const hasProducts = guide.productTotal > 0;
const hasVehicles = guide.vehicles.length > 0;
const hasNearbyAlternatives =
  guide.equivalents.length > 0 || guide.upgrades.length > 0 || guide.related.length > 0;
const hasPopularComparisons = guide.popularComparisons.length > 0;
const sidebarPopularComparisons = guide.popularComparisons.filter(
  (link) => link.href !== guide.compareHref,
);
const rimIn = specs.wheelDiameterIn;
const applicableCategories = getTireSizeHubCategories(hub.entry).map((slug) => ({
  slug,
  label: TIRE_CATEGORY_HUBS[slug].label,
  href: tireCategoryHubPath(slug),
}));
const primaryCategory = getPrimaryTireSizeHubCategory(hub.entry);
const primaryCategoryHub = {
  label: TIRE_CATEGORY_HUBS[primaryCategory].label,
  href: tireCategoryHubPath(primaryCategory),
};

const vehiclesNote =
  hub.entry.category === 'performance' || hub.entry.category === 'passenger'
    ? 'Documented fitment mappings for research — confirm the door placard, wheel diameter, and load/speed markings before treating any vehicle as a guaranteed fit.'
    : 'Documented fitment mappings for research. Vehicle clearance depends on trim, wheel offset, suspension height, and tire model — confirm fitment before buying.';

const closingTitle = `Next step: compare ${displaySize} before changing tire sizes`;
const closingCopy =
  guide.nearbyCompareExamples.length > 0
    ? `Compare ${displaySize} against nearby sizes like ${guide.nearbyCompareExamples.join(', ')} to check diameter change, speedometer impact, clearance, and fitment tradeoffs.`
    : `Compare ${displaySize} against nearby sizes to check diameter change, speedometer impact, clearance, and fitment tradeoffs.`;

const CALC_ICONS: Record<string, HubIconName> = {
  [CALCULATOR_PATHS.tireSize]: 'calculator',
  [CALCULATOR_PATHS.tireComparison]: 'split-square-vertical',
  [CALCULATOR_PATHS.tireDiameter]: 'ruler',
  [CALCULATOR_PATHS.wheelOffset]: 'disc',
  [CALCULATOR_PATHS.gearRatio]: 'rotate-cw',
};

const relatedCalculators = SITE_CALCULATORS
  .filter(
    (calc) =>
      calc.href !== CALCULATOR_PATHS.tireSize &&
      calc.href !== CALCULATOR_PATHS.tireComparison,
  )
  .map((calc) => ({
    label: calc.label,
    description: calc.description,
    href: calc.href,
    icon: CALC_ICONS[calc.href] ?? 'calculator',
  }));

const faq = guide.faq;
const availableTireModels = guide.products.map(tireProductToVerifiedModel);
const relatedSizeDestinations = new Set(guide.related.map((chip) => chip.href));
const sidebarUpgrades = guide.upgrades.filter(
  (chip) => !relatedSizeDestinations.has(chip.href),
);

const lastReviewedLabel = formatEditorialDate(SITE_CONTENT_UPDATED);

const PROVENANCE_LABEL: Record<string, string> = {
  calculated: 'Calculated',
  manufacturer: 'Manufacturer',
  standard: 'Standard',
};

const methodologySteps = METHODOLOGY.steps.slice(0, 3);
---

<div class="ref-275 guide-275">
  <HubBreadcrumb
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Tire Sizes', href: '/tire-sizes/' },
      { label: primaryCategoryHub.label, href: primaryCategoryHub.href },
      { label: displaySize },
    ]}
  />

  <div class="guide-275__layout mt-6 lg:mt-8">
    <div class="guide-275__main min-w-0 space-y-8">
      <!-- 1–2. Size-specific H1 + short explanation -->
      <Premium275Hero hub={hub} coverage={guide.coverage} />

      <!-- 3. Main dimensions and calculated specifications -->
      <section class="guide-card" id="at-a-glance" aria-labelledby="glance-heading">
        <h2 id="glance-heading" class="guide-card__title">At a Glance</h2>
        <p class="guide-card__lead">
          Nominal dimensions calculated from the {displaySize} size code
          ({specs.widthMm}/{specs.aspectRatio}R{rimIn}). Load range and speed rating come from
          indexed manufacturer products when available.
        </p>
        <div class="guide-glance">
          {guide.glance.map((row) => (
            <div class="guide-glance__item">
              <p class="guide-glance__label">
                {row.label}
                <span class="guide-glance__provenance">{PROVENANCE_LABEL[row.provenance]}</span>
              </p>
              <p class="guide-glance__value">{row.value}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Data-backed contextual links to applicable category hubs -->
      <section class="guide-card" id="applicable-categories" aria-labelledby="categories-heading">
        <h2 id="categories-heading" class="guide-card__title">Applicable Tire Categories</h2>
        <p class="guide-card__lead">
          Based on this size’s editorial category and exact-size product metadata. A size may
          support several uses without every product in the size belonging to every category.
        </p>
        <div class="guide-category-links">
          {applicableCategories.map((category) => (
            <a href={category.href}>
              <span>{category.label} tire sizes</span>
              <HubIcon name="chevron-right" class="h-3.5 w-3.5 shrink-0 text-primary" />
            </a>
          ))}
        </div>
      </section>

      <!-- 4. Formula and methodology disclosure -->
      <section class="guide-card" id="methodology" aria-labelledby="methodology-heading">
        <h2 id="methodology-heading" class="guide-card__title">Formula &amp; Methodology</h2>
        <p class="guide-card__lead">{METHODOLOGY.intro}</p>
        <ol class="guide-methodology">
          {methodologySteps.map((step) => (
            <li>
              <strong>{step.title}.</strong> {step.detail}
            </li>
          ))}
        </ol>
        <p class="guide-methodology__note">
          Rim diameter shown on this page is always {rimIn}" — the bead-seat diameter encoded in {displaySize}.
        </p>
      </section>

      <!-- 5–6. Best-use cases and trade-offs -->
      <section class="guide-trio" aria-label="Size overview">
        <article class="guide-card guide-trio__card">
          <h2 class="guide-card__title">Best For</h2>
          <ul class="guide-bullets">
            {guide.bestFor.map((item) => (
              <li class="guide-bullets__item">
                <span class="guide-bullets__icon guide-bullets__icon--good" aria-hidden="true">
                  <HubIcon name="check" class="h-3.5 w-3.5 shrink-0" />
                </span>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="guide-card guide-trio__card">
          <h2 class="guide-card__title">Consider Another Size If</h2>
          <ul class="guide-bullets">
            {guide.considerIf.map((item) => (
              <li class="guide-bullets__item">
                <span class="guide-bullets__icon guide-bullets__icon--warn" aria-hidden="true">
                  <HubIcon name="x" class="h-3.5 w-3.5 shrink-0" />
                </span>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="guide-card guide-trio__card">
          <h2 class="guide-card__title">Real-World Impact</h2>
          <ul class="guide-bullets">
            {guide.realWorldImpact.map((item) => (
              <li class="guide-bullets__item">
                <span
                  class:list={[
                    'guide-bullets__dot',
                    item.tone === 'good' ? 'guide-bullets__dot--good' : 'guide-bullets__dot--warn',
                  ]}
                  aria-hidden="true"
                ></span>
                <span>{item.text}</span>
              </li>
            ))}
          </ul>
        </article>
      </section>

      <!-- 7. Verified vehicle examples (only when available) -->
      {hasVehicles && (
        <section class="guide-card" id="vehicles-fitment" aria-labelledby="vehicles-heading">
          <div class="guide-card__head">
            <div>
              <h2 id="vehicles-heading" class="guide-card__title !mb-0">Verified Vehicle Examples</h2>
              <p class="mt-1 text-xs text-muted">
                Documented OE or commonly associated platforms for {displaySize}.
              </p>
            </div>
          </div>
          <ul class="guide-vehicle-chips mt-4">
            {guide.vehicles.map((v) => (
              <li class="guide-vehicle-chip">
                {v.manufacturer} {v.model}
                {v.trim ? ` ${v.trim}` : ''}
                {v.yearRange ? ` (${v.yearRange})` : ''}
              </li>
            ))}
          </ul>
          <p class="guide-vehicles-note">{vehiclesNote}</p>
        </section>
      )}

      <!-- 8. Real tire products (exact size only) -->
      {hasProducts && (
        <section class="guide-card" id="available-tires" aria-labelledby="tires-heading">
          <div class="guide-card__head">
            <div>
              <h2 id="tires-heading" class="guide-card__title !mb-0">Real Tires Available in This Size</h2>
              <p class="mt-1 text-xs text-muted">
                Indexed manufacturer models confirmed in exact size {displaySize}
              </p>
            </div>
            {guide.fullSpecProducts.length > 0 && (
              <a href="#spec-comparison" class="guide-link">View all indexed tires →</a>
            )}
          </div>
          <p class="guide-source-line">
            Manufacturer-provided product/spec data from Michelin, Goodyear, BFGoodrich, Toyo, and Falken where available.
          </p>
          <div class="mt-4">
            <HubAvailableTires
              client:load
              displaySize={displaySize}
              models={availableTireModels}
            />
          </div>
        </section>
      )}

      {guide.useCases.length > 0 && (
        <section class="guide-card" id="best-by-use" aria-labelledby="usecase-heading">
          <h2 id="usecase-heading" class="guide-card__title">Best Options by Use Case</h2>
          <div class="guide-usecases">
            {guide.useCases.slice(0, 4).map((bucket) => (
              <div class="guide-usecase">
                <h3 class="guide-usecase__title">{bucket.label}</h3>
                <p class="guide-usecase__desc">{bucket.description}</p>
                <ul class="guide-usecase__list">
                  {bucket.products.slice(0, 3).map((p) => (
                    <li>
                      <span class="font-semibold text-heading">{canonicalProductBrand(p)}</span>
                      {' '}{formatTireModelDisplayName(p.model)}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- 9. Nearby alternative sizes -->
      {hasNearbyAlternatives && (
        <section class="guide-card" id="nearby-alternatives" aria-labelledby="nearby-heading">
          <div class="guide-card__head">
            <div>
              <h2 id="nearby-heading" class="guide-card__title !mb-0">Nearby Alternative Sizes</h2>
              <p class="mt-1 text-xs text-muted">
                Equivalent, upgrade, and related sizes near {displaySize}.
              </p>
            </div>
            <a href="/tire-sizes/" class="guide-link">View all →</a>
          </div>

          {guide.equivalents.length > 0 && (
            <div class="mt-4">
              <h3 class="guide-subhead">Equivalent tire sizes</h3>
              <div class="guide-chips">
                {guide.equivalents.map((chip) => {
                  const pos = chip.diameterDiffPercent >= 0;
                  return (
                    <a href={chip.href} class="guide-chip">
                      <span class="guide-chip__size">{chip.size}</span>
                      <span class:list={['guide-chip__pct', pos ? 'is-pos' : 'is-neg']}>
                        {pos ? '+' : ''}{chip.diameterDiffPercent.toFixed(2)}%
                      </span>
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          {guide.upgrades.length > 0 && (
            <div class="mt-4">
              <h3 class="guide-subhead">Popular upgrades</h3>
              <div class="guide-chips">
                {guide.upgrades.map((chip) => (
                  <a href={chip.href} class="guide-chip guide-chip--upgrade">
                    <span class="guide-chip__size">{chip.size}</span>
                    <span class="guide-chip__pct is-pos">
                      +{chip.diameterDiffPercent.toFixed(2)}%
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </section>
      )}

      <!-- 10. Popular comparison links -->
      {hasPopularComparisons && (
        <section class="guide-card" id="popular-comparisons" aria-labelledby="comparisons-heading">
          <h2 id="comparisons-heading" class="guide-card__title">Popular Comparisons</h2>
          <p class="guide-card__lead">
            Side-by-side diameter, speedometer, and clearance math for {displaySize}.
          </p>
          <ul class="guide-compare-links">
            {guide.popularComparisons.map((link) => (
              <li>
                <a href={link.href}>
                  <span>{displaySize} vs {link.size}</span>
                  <HubIcon name="chevron-right" class="h-3.5 w-3.5 shrink-0 text-primary" />
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {guide.fullSpecProducts.length > 0 && (
        <ProductSpecComparison
          client:load
          products={guide.fullSpecProducts}
          initialVisible={6}
          startCollapsed={true}
          description={`Compare tread depth, weight, max load, pressure, and revs per mile for full-spec ${displaySize} products.`}
        />
      )}

      {faq.length > 0 && (
        <section class="guide-card" id="faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading" class="guide-card__title">FAQ</h2>
          <div class="guide-faq">
            {faq.map((item) => (
              <details class="guide-faq__item">
                <summary>
                  <span>{item.question}</span>
                  <HubIcon name="chevron-right" class="guide-faq__chevron h-4 w-4 shrink-0" />
                </summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- 14. Safety and fitment limitations -->
      <section class="guide-card" id="safety-fitment" aria-labelledby="safety-heading">
        <h2 id="safety-heading" class="guide-card__title">Safety &amp; Fitment Limitations</h2>
        <ul class="guide-safety">
          <li>
            Calculated dimensions are nominal planning baselines from the size code — mounted tires can differ with tread depth, inflation, rim width, and production tolerance.
          </li>
          <li>
            Always confirm {displaySize} against the door placard or owner’s manual, including load index, load range, and speed rating for your vehicle.
          </li>
          <li>
            Changing diameter affects speedometer accuracy, gearing feel, ABS/traction calibration, and clearance at fenders, control arms, and the spare well.
          </li>
          <li>
            Vehicle examples and product cards are not a guarantee of fitment. Verify wheel diameter ({rimIn}"), offset, and suspension setup before buying.
          </li>
        </ul>
      </section>

      <!-- Sources and last-reviewed date -->
      <section class="guide-card" id="sources-review" aria-labelledby="sources-heading">
        <h2 id="sources-heading" class="guide-card__title">Sources &amp; Review</h2>
        <p class="guide-card__lead">
          Dimensions are calculated from the tire size label; product rows and fitment mappings come from documented manufacturer and OE sources where available.
        </p>
        <ul class="guide-sources">
          {DATA_SOURCES.slice(0, 4).map((source) => (
            <li>
              <strong>{source.name}.</strong> {source.detail}
            </li>
          ))}
        </ul>
        <div class="guide-byline">
          <LastUpdated date={SITE_CONTENT_UPDATED} label="Content last reviewed" />
        </div>
      </section>

      <section class="guide-closing" aria-labelledby="closing-heading">
        <h2 id="closing-heading" class="guide-closing__title">
          {closingTitle}
        </h2>
        <p class="guide-closing__copy">
          {closingCopy}
        </p>
        <div class="guide-closing__actions">
          <a href={guide.compareHref} class="guide-btn guide-btn--accent">{guide.compareLabel}</a>
          {hasProducts ? (
            <a href="#available-tires" class="guide-btn guide-btn--outline">See {displaySize} product data</a>
          ) : (
            <a href={guide.calculatorHref} class="guide-btn guide-btn--outline">Open size calculator</a>
          )}
        </div>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="guide-275__sidebar">
      <div class="guide-sidebar-rail">
        <div class="guide-card">
          <h3 class="guide-card__title">Quick Facts</h3>
          <p class="guide-facts__note">Calculated from the size code unless marked manufacturer.</p>
          <dl class="guide-facts">
            <div><dt>Overall diameter <span class="guide-facts__tag">Calc.</span></dt><dd>{specs.overallDiameterIn.toFixed(2)}"</dd></div>
            <div><dt>Section width <span class="guide-facts__tag">Calc.</span></dt><dd>{specs.sectionWidthIn.toFixed(2)}" ({specs.widthMm} mm)</dd></div>
            <div><dt>Sidewall height <span class="guide-facts__tag">Calc.</span></dt><dd>{specs.sidewallIn.toFixed(2)}"</dd></div>
            <div><dt>Circumference <span class="guide-facts__tag">Calc.</span></dt><dd>{specs.circumferenceIn.toFixed(2)}"</dd></div>
            <div><dt>Revs per mile <span class="guide-facts__tag">Calc.</span></dt><dd>{Math.round(specs.revsPerMile)}</dd></div>
            <div><dt>Rim diameter <span class="guide-facts__tag">Calc.</span></dt><dd>{rimIn}"</dd></div>
            <div><dt>Aspect ratio <span class="guide-facts__tag">Calc.</span></dt><dd>{specs.aspectRatio}%</dd></div>
            {guide.loadRanges.length > 0 && (
              <div><dt>Load range <span class="guide-facts__tag">Mfr.</span></dt><dd>{guide.loadRanges.slice(0, 4).join(' / ')}</dd></div>
            )}
            {guide.speedRatings.length > 0 && (
              <div><dt>Speed rating <span class="guide-facts__tag">Mfr.</span></dt><dd>{guide.speedRatings.slice(0, 5).join(' / ')}</dd></div>
            )}
            <div><dt>Construction <span class="guide-facts__tag">Std.</span></dt><dd>Radial</dd></div>
          </dl>
        </div>

        <div class="guide-card guide-card--dark">
          <h3 class="guide-card__title guide-card__title--light">Compare This Size</h3>
          <p class="guide-card__copy guide-card__copy--light">
            See diameter, speedometer, and clearance change vs another size.
          </p>
          <a href={guide.compareHref} class="guide-btn guide-btn--accent">{guide.compareLabel}</a>
        </div>

        {sidebarPopularComparisons.length > 0 && (
          <div class="guide-card">
            <h3 class="guide-card__title">Popular Comparisons</h3>
            <ul class="guide-side-links">
              {sidebarPopularComparisons.map((link) => (
                <li>
                  <a href={link.href}>
                    <span>vs {link.size}</span>
                    <HubIcon name="chevron-right" class="h-3.5 w-3.5 shrink-0 text-primary" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {guide.related.length > 0 && (
          <div class="guide-card">
            <h3 class="guide-card__title">Related Tire Sizes</h3>
            <ul class="guide-side-links">
              {guide.related.map((chip) => (
                <li>
                  <a href={chip.href}>
                    <span>{chip.size}</span>
                    <HubIcon name="chevron-right" class="h-3.5 w-3.5 shrink-0 text-primary" />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {sidebarUpgrades.length > 0 && (
          <div class="guide-card">
            <h3 class="guide-card__title">Popular Upgrades</h3>
            <ul class="guide-side-links">
              {sidebarUpgrades.map((chip) => (
                <li>
                  <a href={chip.href}>
                    <span>{chip.size}</span>
                    <span class="guide-side-links__pct">+{chip.diameterDiffPercent.toFixed(1)}%</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {guide.brands.length > 0 && (
          <div class="guide-card">
            <h3 class="guide-card__title">Brand Availability</h3>
            <ul class="guide-brands">
              {guide.brands.map((brand) => (
                <li>
                  <span class="guide-brands__check" aria-hidden="true">
                    <HubIcon name="check" class="h-3 w-3 shrink-0" />
                  </span>
                  {brand}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="guide-card">
          <h3 class="guide-card__title">Data Coverage</h3>
          <dl class="guide-coverage">
            <div><dt>Unique tire models</dt><dd>{guide.coverage.uniqueModelCount}</dd></div>
            <div><dt>Service variants</dt><dd>{guide.coverage.serviceVariantCount}</dd></div>
            <div><dt>Full-spec products</dt><dd>{guide.coverage.fullSpecProducts}</dd></div>
            <div><dt>Brands indexed</dt><dd>{guide.coverage.brands.length}</dd></div>
            <div><dt>Source type</dt><dd>Calculated + manufacturer</dd></div>
            <div><dt>Last reviewed</dt><dd>{lastReviewedLabel}</dd></div>
          </dl>
        </div>

        <div class="guide-card">
          <h3 class="guide-card__title">Tire Size Calculator</h3>
          <p class="guide-card__copy">Convert {displaySize} into diameter, width, and revs/mile.</p>
          <a href={guide.calculatorHref} class="guide-btn guide-btn--outline">Calculate Now</a>
        </div>

        <div class="guide-card guide-related-calcs" aria-label="Related calculators">
          <h2 class="guide-card__title guide-related-calcs__title">
            <HubIcon name="tools" class="h-3.5 w-3.5 shrink-0 text-primary" />
            Related Calculators
          </h2>
          <ul class="guide-related-calcs__list">
            {relatedCalculators.map((calc) => (
              <li>
                <a href={calc.href} class="guide-calc-link group">
                  <span class="guide-calc-link__icon">
                    <HubIcon name={calc.icon} class="h-3.5 w-3.5 shrink-0" />
                  </span>
                  <span class="min-w-0 flex-1">
                    <span class="guide-calc-link__label">{calc.label}</span>
                    <span class="guide-calc-link__desc">{calc.description}</span>
                  </span>
                  <HubIcon
                    name="chevron-right"
                    class="guide-calc-link__chevron h-3.5 w-3.5 shrink-0"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </aside>
  </div>
</div>

<style>
  .guide-275__layout {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 1024px) {
    .guide-275__layout {
      grid-template-columns: minmax(0, 1fr) 18.5rem;
      gap: 2rem;
      align-items: start;
    }
  }
  @media (min-width: 1280px) {
    .guide-275__layout {
      grid-template-columns: minmax(0, 1fr) 20rem;
      gap: 2.5rem;
    }
  }

  .guide-sidebar-rail {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .guide-sidebar-rail {
      position: sticky;
      top: 5.5rem;
    }
  }

  .guide-card {
    border-radius: 0.875rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 1.125rem 1.25rem;
    box-shadow: 0 1px 3px rgb(15 23 42 / 0.04);
  }
  .guide-card--dark {
    background: #0f172a;
    border-color: #0f172a;
  }
