---
import HubIcon from '../HubIcon.astro';
import type { QuickTakeData } from '../../../lib/tire-size-quick-take';

interface Props {
  data: QuickTakeData;
}

const { data } = Astro.props;
---

<section class="ref-section quick-take">
  <h2 class="ref-section__title text-2xl font-bold tracking-tight text-heading">Quick Take</h2>

  <div class="quick-take__card-wrap ref-featured-wrap">
    <div class="quick-take__card ref-featured-card rounded-[1rem] border border-primary/15 bg-primary-light/35 ref-card-pad">
    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <div class="quick-take__column">
        <div class="flex items-center gap-2.5">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-success/10 text-success ring-1 ring-success/15">
            <HubIcon name="thumbs-up" class="h-[1.125rem] w-[1.125rem]" />
          </span>
          <h3 class="text-base font-bold text-heading">Best For</h3>
        </div>
        <ul class="mt-4 space-y-3">
          {data.bestFor.map((item) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-body">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10 text-success">
                <HubIcon name="check" class="h-3 w-3" />
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="quick-take__column lg:border-l lg:border-border/70 lg:pl-8">
        <div class="flex items-center gap-2.5">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent ring-1 ring-accent/15">
            <HubIcon name="alert-triangle" class="h-[1.125rem] w-[1.125rem]" />
          </span>
          <h3 class="text-base font-bold text-heading">Consider Another Size If</h3>
        </div>
        <ul class="mt-4 space-y-3">
          {data.considerAnotherSizeIf.map((item) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-body">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-danger/10 text-danger">
                <HubIcon name="x" class="h-3 w-3" />
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 1023px) {
    .quick-take__column + .quick-take__column {
      border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
      padding-top: 1.5rem;
    }
  }
</style>
