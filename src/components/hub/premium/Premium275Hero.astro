---
import type { TireSizeHubData } from '../../../lib/tire-size-hub';
import { buildHeroSpecCards } from '../../../lib/tire-size-premium';
import {
  getExpertIntroBlockForTireSize,
} from '../../../lib/tire-size-expert-intro';
import type { TireSizeDataCoverage } from '../../../lib/tire-size-products';
import HubCategoryBadge from '../HubCategoryBadge.astro';
import HubIcon from '../HubIcon.astro';
import Premium275TireViz from './Premium275TireViz.astro';

interface Props {
  hub: TireSizeHubData;
  coverage?: TireSizeDataCoverage | null;
}

const { hub, coverage = null } = Astro.props;
const { displaySize, specs, categoryLabel, intro } = hub;
const specCards = buildHeroSpecCards(specs);
const expertBlock = getExpertIntroBlockForTireSize(
  { size: hub.entry.size, specs, category: hub.entry.category },
  coverage,
);
const introParagraph = expertBlock?.paragraph ?? intro;
const fitmentNotes = expertBlock?.fitmentNotes ?? [];
---

<section class="premium-hero">
  <div class="premium-hero__head">
    <HubCategoryBadge category={hub.entry.category} label={categoryLabel} />
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-heading sm:text-3xl lg:text-[2.125rem] lg:leading-tight">
      {displaySize} Tire Size
    </h1>
  </div>

  <div class="premium-hero__viz">
    <Premium275TireViz category={hub.entry.category} size={hub.entry.size} specs={specs} specCards={specCards} />
  </div>

  <div class="premium-hero__intro">
    <p class="premium-hero__intro-copy max-w-4xl text-sm leading-snug text-body sm:text-[0.9375rem]">
      {introParagraph}
    </p>
    {fitmentNotes.length > 0 && (
      <ul class="premium-hero__notes" aria-label="Fitment notes">
        {fitmentNotes.map((note) => (
          <li class="premium-hero__notes-item">
            <span class="premium-hero__notes-icon" aria-hidden="true">
              <HubIcon name="check" class="h-3.5 w-3.5 shrink-0" />
            </span>
            <span class="premium-hero__notes-text">{note}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .premium-hero {
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    border-radius: var(--ref-content-radius, 1.125rem);
    border: 1px solid color-mix(in srgb, var(--color-primary) 10%, var(--color-border));
    background-color: color-mix(in srgb, var(--color-primary-light) 18%, var(--color-surface));
    box-shadow:
      0 4px 24px -6px rgb(15 23 42 / 0.08),
      0 2px 8px -2px rgb(var(--color-primary-rgb) / 0.05),
      inset 0 1px 0 rgb(255 255 255 / 0.65);
  }

  .premium-hero__head {
    padding: 0.875rem var(--ref-section-px, 1.25rem) 0.625rem;
  }

  .premium-hero__viz {
    padding: 0 var(--ref-section-px, 1.25rem) 0.625rem;
  }

  .premium-hero__intro {
    border-top: 1px solid color-mix(in srgb, var(--color-border) 75%, transparent);
    padding: 0.75rem var(--ref-section-px, 1.25rem) 0.875rem;
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
  }

  .premium-hero__notes {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    max-width: 48rem;
  }

  .premium-hero__notes-item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-body);
  }

  .premium-hero__notes-icon {
    display: inline-flex;
    height: 1.125rem;
    width: 1.125rem;
    min-width: 1.125rem;
    flex: 0 0 1.125rem;
    align-items: center;
    justify-content: center;
    margin-top: 0.12rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-success) 12%, transparent);
    color: var(--color-success);
  }

  .premium-hero__notes-icon :global(svg) {
    width: 0.75rem !important;
    height: 0.75rem !important;
    max-width: 0.75rem !important;
    max-height: 0.75rem !important;
    display: block;
  }

  .premium-hero__notes-text {
    flex: 1 1 auto;
    min-width: 0;
  }

  @media (max-width: 639px) {
    .premium-hero__head {
      padding-top: 0.6875rem;
      padding-bottom: 0.5rem;
    }

    .premium-hero__viz {
      padding-bottom: 0.5rem;
    }

    .premium-hero__intro {
      padding-top: 0.5625rem;
      padding-bottom: 0.6875rem;
    }
  }

  @media (min-width: 640px) {
    .premium-hero__head {
      padding-top: 1rem;
      padding-bottom: 0.75rem;
    }

    .premium-hero__viz {
      padding-bottom: 0.75rem;
    }

    .premium-hero__intro {
      padding-top: 0.75rem;
      padding-bottom: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .premium-hero__head {
      padding-top: 1.125rem;
      padding-bottom: 0.75rem;
    }

    .premium-hero__intro {
      padding-top: 0.875rem;
      padding-bottom: 1.125rem;
    }
  }
</style>
