---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<section id={id} class="hub-section border-t border-border/80 pt-10 first:border-t-0 first:pt-0">
  <div class="mb-6">
    <h2 class="text-xl font-semibold tracking-tight text-heading sm:text-2xl">{title}</h2>
    {subtitle && <p class="mt-1.5 max-w-3xl text-sm text-body">{subtitle}</p>}
  </div>
  <slot />
</section>
