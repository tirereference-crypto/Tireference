---
import HubIcon from './HubIcon.astro';
import type { HubIconName } from '../../lib/hub-icons';
import type { PremiumUpgradeCard } from '../../lib/tire-size-premium';

interface Props {
  upgrades: PremiumUpgradeCard[];
  displaySize: string;
}

const { upgrades, displaySize } = Astro.props;

const difficultyStyle = {
  Easy: 'hub-upgrade-card--easy',
  Moderate: 'hub-upgrade-card--moderate',
  Advanced: 'hub-upgrade-card--advanced',
};

const difficultyBadge = {
  Easy: 'bg-success/10 text-success border-success/20',
  Moderate: 'bg-accent/10 text-accent border-accent/20',
  Advanced: 'bg-danger/10 text-danger border-danger/20',
};

const difficultyIcon: Record<PremiumUpgradeCard['difficulty'], HubIconName> = {
  Easy: 'chevron-up',
  Moderate: 'trending-up',
  Advanced: 'rocket',
};
---

<div class="hub-sidebar-widget hub-sidebar-widget--upgrades">
  <h3 class="hub-sidebar-widget__title">
    <HubIcon name="trending-up-section" class="h-3.5 w-3.5 text-primary" />
    Popular Upgrades
  </h3>
  <p class="hub-sidebar-widget__subtitle">Common upsize paths from {displaySize}.</p>

  <div class="mt-3 space-y-2">
    {upgrades.map((card) => (
      <a
        href={card.href}
        class:list={[
          'hub-upgrade-card group block rounded-[0.75rem] border bg-surface p-2.5 transition-[border-color,box-shadow,transform] duration-200 hover:-translate-y-px hover:shadow-[0_4px_14px_-4px_rgb(15_23_42/0.12)]',
          difficultyStyle[card.difficulty],
        ]}
      >
        <span
          class:list={[
            'inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide',
            difficultyBadge[card.difficulty],
          ]}
        >
          <HubIcon name={difficultyIcon[card.difficulty]} class="h-3 w-3 opacity-80" />
          {card.difficulty}
        </span>

        <p class="mt-1.5 font-mono text-sm font-bold text-heading group-hover:text-primary">{card.size}</p>

        <div class="mt-1.5 flex items-center gap-3 text-[11px]">
          <span class="text-muted">
            Diameter{' '}
            <span
              class:list={[
                'font-semibold tabular-nums',
                card.diameterDiffPercent >= 0 ? 'hub-diff-positive' : 'hub-diff-negative',
              ]}
            >
              {card.diameterDiffPercent >= 0 ? '+' : ''}{card.diameterDiffPercent.toFixed(1)}%
            </span>
          </span>
          <span class="text-border" aria-hidden="true">·</span>
          <span class="text-muted">
            Clearance{' '}
            <span
              class:list={[
                'font-semibold tabular-nums',
                card.groundClearanceGainIn >= 0 ? 'hub-diff-positive' : 'hub-diff-negative',
              ]}
            >
              {card.groundClearanceGainIn >= 0 ? '+' : ''}{card.groundClearanceGainIn.toFixed(2)} in
            </span>
          </span>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .hub-upgrade-card--easy {
    border-color: color-mix(in srgb, var(--color-success) 22%, var(--color-border));
    background-color: color-mix(in srgb, var(--color-success) 3%, var(--color-surface));
  }

  .hub-upgrade-card--moderate {
    border-color: color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
  }

  .hub-upgrade-card--advanced {
    border-color: color-mix(in srgb, var(--color-danger) 18%, var(--color-border));
  }

  .hub-upgrade-card--easy:hover {
    border-color: color-mix(in srgb, var(--color-success) 35%, var(--color-border));
  }

  .hub-upgrade-card--moderate:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
  }

  .hub-upgrade-card--advanced:hover {
    border-color: color-mix(in srgb, var(--color-danger) 30%, var(--color-border));
  }
</style>
