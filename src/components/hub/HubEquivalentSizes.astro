---
import type { EquivalentSize } from '../../lib/tire-size-hub';

interface Props {
  equivalents: EquivalentSize[];
}

const { equivalents } = Astro.props;
const maxPct = Math.max(...equivalents.map((e) => Math.abs(e.diameterDiffPercent)), 3);
---

{
  equivalents.length > 0 ? (
    <ul class="space-y-3">
      {equivalents.map((eq) => {
        const barWidth = Math.min(100, (Math.abs(eq.diameterDiffPercent) / maxPct) * 100);
        const isPositive = eq.diameterDiffPercent >= 0;
        return (
          <li>
            <a
              href={eq.href}
              class="block rounded-xl border border-border bg-surface p-4 shadow-card transition-colors hover:border-primary/30 hover:bg-surface-subtle/50"
            >
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="font-mono text-base font-semibold text-heading">{eq.size}</span>
                <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold tabular-nums ${isPositive ? 'bg-success/10 text-success' : 'bg-danger/10 text-danger'}`}>
                  {isPositive ? '+' : ''}{eq.diameterDiffPercent.toFixed(1)}%
                </span>
              </div>
              <p class="mt-1 text-xs text-muted">{eq.diameterIn.toFixed(2)} in overall diameter</p>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-surface-subtle">
                <div
                  class={`h-full rounded-full ${isPositive ? 'bg-success' : 'bg-danger'}`}
                  style={`width: ${barWidth}%`}
                />
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="text-sm text-muted">No other sizes in our dataset within ±3% overall diameter.</p>
  )
}
