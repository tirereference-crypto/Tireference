---
import type { SummaryBarItem } from '../../lib/tire-size-hub-content';

interface Props {
  items: SummaryBarItem[];
}

const { items } = Astro.props;
---

<div class="-mt-2 mb-2 flex flex-wrap gap-2 rounded-xl border border-border bg-surface px-4 py-3 shadow-card sm:gap-4 sm:px-5">
  {
    items.map((item) => (
      <div class="flex min-w-0 items-baseline gap-1.5 text-sm">
        <span class="shrink-0 font-medium text-muted">{item.label}:</span>
        <span class="truncate font-semibold text-heading">{item.value}</span>
      </div>
    ))
  }
</div>
