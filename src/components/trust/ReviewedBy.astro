---
import { EDITORIAL_REVIEWER, type EditorialPerson } from '../../lib/editorial';

interface Props {
  person?: EditorialPerson;
  /** "inline" = compact byline row; "card" = bordered block with bio. */
  variant?: 'inline' | 'card';
  class?: string;
}

const {
  person = EDITORIAL_REVIEWER,
  variant = 'inline',
  class: className = '',
} = Astro.props;
---

{variant === 'card' ? (
  <div class:list={['flex items-start gap-3 rounded-card border border-border bg-surface p-4', className]}>
    {
      person.photoUrl ? (
        <img
          src={person.photoUrl}
          alt=""
          class="h-10 w-10 shrink-0 rounded-full object-cover ring-2 ring-success/20"
          width="40"
          height="40"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-success/10 text-success">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </span>
      )
    }
    <div class="min-w-0">
      <p class="text-[11px] font-semibold uppercase tracking-wider text-muted">Reviewed by</p>
      <a href={person.profileUrl} class="font-bold text-heading hover:text-primary">{person.name}</a>
      <p class="text-xs text-muted">{person.role}</p>
      <p class="mt-1.5 text-sm leading-relaxed text-body">{person.bio}</p>
    </div>
  </div>
) : (
  <span class:list={['inline-flex items-center gap-2', className]}>
    {
      person.photoUrl ? (
        <img
          src={person.photoUrl}
          alt=""
          class="h-7 w-7 shrink-0 rounded-full object-cover ring-2 ring-success/20"
          width="28"
          height="28"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-success/10 text-success" aria-hidden="true">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </span>
      )
    }
    <span class="text-sm leading-tight">
      <span class="text-muted">Reviewed by </span>
      <a href={person.profileUrl} class="font-semibold text-heading hover:text-primary">{person.name}</a>
    </span>
  </span>
)}
