---
import Author from './Author.astro';
import ReviewedBy from './ReviewedBy.astro';
import LastUpdated from './LastUpdated.astro';
import type { EditorialPerson } from '../../lib/editorial';

interface Props {
  author?: EditorialPerson;
  reviewer?: EditorialPerson;
  /** ISO date; defaults to the site-wide review date inside LastUpdated. */
  updated?: string;
  class?: string;
}

const { author, reviewer, updated, class: className = '' } = Astro.props;
---

<div
  class:list={[
    'flex flex-wrap items-center gap-x-4 gap-y-2 rounded-card border border-border bg-surface-subtle/60 px-3.5 py-2.5',
    className,
  ]}
>
  <Author person={author} variant="inline" />
  <span class="hidden h-4 w-px bg-border sm:block" aria-hidden="true"></span>
  <ReviewedBy person={reviewer} variant="inline" />
  <span class="hidden h-4 w-px bg-border sm:block" aria-hidden="true"></span>
  <LastUpdated date={updated} class="ml-auto" />
</div>
