---
import { METHODOLOGY, type EditorialStep } from '../../lib/editorial';

interface Props {
  heading?: string;
  intro?: string;
  steps?: EditorialStep[];
  class?: string;
}

const {
  heading = 'Methodology',
  intro = METHODOLOGY.intro,
  steps = METHODOLOGY.steps,
  class: className = '',
} = Astro.props;
---

<div class:list={['rounded-card border border-border bg-surface p-4', className]}>
  <div class="flex items-center gap-2">
    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-primary-light text-primary" aria-hidden="true">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 2v6l-5 9a2 2 0 0 0 1.8 3h12.4a2 2 0 0 0 1.8-3l-5-9V2" />
        <path d="M8 2h8" /><path d="M7.5 14h9" />
      </svg>
    </span>
    <h3 class="text-sm font-bold text-heading">{heading}</h3>
  </div>
  {intro && <p class="mt-2 text-xs leading-relaxed text-muted">{intro}</p>}
  <ul class="mt-3 space-y-2.5">
    {steps.map((step) => (
      <li class="flex gap-2.5 text-sm leading-relaxed text-body">
        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-primary/70" aria-hidden="true"></span>
        <span><span class="font-semibold text-heading">{step.title}.</span> {step.detail}</span>
      </li>
    ))}
  </ul>
</div>
