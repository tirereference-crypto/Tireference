---
import Author from './Author.astro';
import ReviewedBy from './ReviewedBy.astro';
import { toEditorialPerson } from '../../lib/people';
import type { Person } from '../../data/people';

interface Props {
  person: Person;
  class?: string;
}

const { person, class: className = '' } = Astro.props;
const editorial = toEditorialPerson(person);
---

<a
  href={editorial.profileUrl}
  class:list={['person-card', className]}
  aria-label={`View ${person.name}'s profile`}
>
  <span class="person-card__photo-wrap">
    {
      editorial.photoUrl ? (
        <img
          src={editorial.photoUrl}
          alt=""
          class="person-card__photo"
          width="96"
          height="96"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="person-card__initials" aria-hidden="true">{editorial.initials}</span>
      )
    }
  </span>
  <div class="person-card__body">
    <h3 class="person-card__name">{person.name}</h3>
    <p class="person-card__role">{person.role}</p>
    <p class="person-card__bio">{person.bio}</p>
    {
      person.credentials.length > 0 ? (
        <ul class="person-card__credentials">
          {person.credentials.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ) : null
    }
    <span class="person-card__more">
      View profile <span aria-hidden="true">→</span>
    </span>
  </div>
</a>
