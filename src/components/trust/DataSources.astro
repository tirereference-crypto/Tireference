---
import { DATA_SOURCES, type DataSource } from '../../lib/editorial';

interface Props {
  heading?: string;
  sources?: DataSource[];
  class?: string;
}

const {
  heading = 'Data Sources',
  sources = DATA_SOURCES,
  class: className = '',
} = Astro.props;
---

<div class:list={['rounded-card border border-border bg-surface p-4', className]}>
  <div class="flex items-center gap-2">
    <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-info/10 text-info" aria-hidden="true">
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="12" cy="5" rx="8" ry="3" />
        <path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5" />
        <path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" />
      </svg>
    </span>
    <h3 class="text-sm font-bold text-heading">{heading}</h3>
  </div>
  <ul class="mt-3 space-y-2.5">
    {sources.map((source) => (
      <li class="flex gap-2.5 text-sm leading-relaxed text-body">
        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-info/70" aria-hidden="true"></span>
        <span>
          {source.url ? (
            <a href={source.url} class="font-semibold text-heading hover:text-primary">{source.name}</a>
          ) : (
            <span class="font-semibold text-heading">{source.name}</span>
          )}
          {' '}— {source.detail}
        </span>
      </li>
    ))}
  </ul>
</div>
