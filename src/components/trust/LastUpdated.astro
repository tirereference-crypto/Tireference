---
import { SITE_CONTENT_UPDATED, formatEditorialDate } from '../../lib/editorial';

interface Props {
  /** ISO date (yyyy-mm-dd). Defaults to the site-wide review date. */
  date?: string;
  label?: string;
  /** Show a small clock icon before the label. */
  icon?: boolean;
  class?: string;
}

const {
  date = SITE_CONTENT_UPDATED,
  label = 'Updated',
  icon = true,
  class: className = '',
} = Astro.props;

const formatted = formatEditorialDate(date);
---

<span class:list={['inline-flex items-center gap-1.5 text-xs text-muted', className]}>
  {icon && (
    <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </svg>
  )}
  <span>{label} <time datetime={date} class="font-medium text-body">{formatted}</time></span>
</span>
