---
interface Props {
  name: 'size' | 'compare' | 'diameter' | 'offset' | 'gear';
}

const { name } = Astro.props;
---

<span class={`home-calc-icon home-calc-icon--${name}`} aria-hidden="true">
  {
    name === 'size' ? (
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="15" r="9" stroke="#7C3AED" stroke-width="2.5" />
        <circle cx="16" cy="15" r="4" stroke="#7C3AED" stroke-width="2" />
        <path
          d="M7.5 22.5c-1.5-2.5-1.2-5.8 1-8"
          stroke="#7C3AED"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path d="M6 24.5h5.5" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" />
        <path d="M6.5 22.5v4" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" />
        <path d="M8 23.5h1.5M8 25h1.5" stroke="#7C3AED" stroke-width="1.25" stroke-linecap="round" />
      </svg>
    ) : name === 'compare' ? (
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12.5" cy="16" r="8" stroke="#3B82F6" stroke-width="2.5" />
        <circle cx="19.5" cy="16" r="8" stroke="#3B82F6" stroke-width="2.5" />
        <path
          d="M16 10.5v11"
          stroke="#3B82F6"
          stroke-width="2"
          stroke-linecap="round"
          stroke-dasharray="2 2"
        />
      </svg>
    ) : name === 'diameter' ? (
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="9" stroke="#10B981" stroke-width="2.5" />
        <circle cx="16" cy="16" r="5.5" stroke="#10B981" stroke-width="2" />
        <path d="M16 4.5v4M16 23.5v4" stroke="#10B981" stroke-width="2" stroke-linecap="round" />
        <path d="M13.5 6.5h5M13.5 25.5h5" stroke="#10B981" stroke-width="2" stroke-linecap="round" />
        <path
          d="M10 16h-3M25 16h-3"
          stroke="#10B981"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    ) : name === 'offset' ? (
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="9" stroke="#F97316" stroke-width="2.5" />
        <circle cx="16" cy="16" r="3" fill="#F97316" />
        <path
          d="M16 7v4.5M16 20.5V25M7 16h4.5M20.5 16H25"
          stroke="#F97316"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M10.1 10.1l3.2 3.2M18.7 18.7l3.2 3.2M21.9 10.1l-3.2 3.2M13.3 18.7l-3.2 3.2"
          stroke="#F97316"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    ) : (
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="4.5" fill="#EC4899" />
        <path
          d="M16 5.5v3M16 23.5v3M5.5 16h3M23.5 16h3M8.6 8.6l2.1 2.1M21.3 21.3l2.1 2.1M23.4 8.6l-2.1 2.1M10.7 21.3l-2.1 2.1"
          stroke="#EC4899"
          stroke-width="2.25"
          stroke-linecap="round"
        />
        <circle cx="16" cy="16" r="9" stroke="#EC4899" stroke-width="2.25" stroke-dasharray="3.5 2.5" />
      </svg>
    )
  }
</span>
