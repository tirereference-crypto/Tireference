---
import HomeSectionHeader from './HomeSectionHeader.astro';

const blocks = [
  {
    title: 'Accurate Calculations',
    body: 'Our tools use established tire and wheel formulas to provide clear, consistent comparisons.',
  },
  {
    title: 'Practical Results',
    body: 'Understand changes in diameter, clearance, speedometer accuracy and effective gearing.',
  },
  {
    title: 'Built for Real Decisions',
    body: 'Compare options before buying tires, wheels or drivetrain parts.',
  },
] as const;
---

<section class="home-section home-seo-content" aria-labelledby="home-seo-content-title">
  <HomeSectionHeader id="home-seo-content-title" title="Precision Tire Calculations You Can Trust" />

  <div class="home-seo-content__grid">
    {
      blocks.map((block) => (
        <div class="home-seo-content__block">
          <h3 class="home-seo-content__heading">{block.title}</h3>
          <p class="home-seo-content__text">{block.body}</p>
        </div>
      ))
    }
  </div>
</section>
