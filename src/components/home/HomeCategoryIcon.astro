---
import type { HomeCategorySlug } from '../../lib/home-sections';

interface Props {
  name: HomeCategorySlug;
}

const { name } = Astro.props;
---

<span class="home-category-icon" aria-hidden="true">
  {
    name === 'suv' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M4 16l1.5-5.5h13L20 16" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M6.5 16v2.5M17.5 16v2.5" stroke-linecap="round" />
        <circle cx="7.5" cy="18.5" r="1.5" />
        <circle cx="16.5" cy="18.5" r="1.5" />
        <path d="M3 16h18" stroke-linecap="round" />
      </svg>
    ) : name === 'truck' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M3 14h11v5H3z" stroke-linejoin="round" />
        <path d="M14 11h4l3 3v5h-7v-8z" stroke-linejoin="round" />
        <circle cx="7" cy="19" r="1.5" />
        <circle cx="17" cy="19" r="1.5" />
      </svg>
    ) : name === 'off-road' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M3 18l4-8 5 3 4-6 5 11" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M3 18h18" stroke-linecap="round" />
      </svg>
    ) : name === 'passenger' || name === 'touring' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M5 15l1.5-4h11L19 15" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="7.5" cy="17.5" r="1.5" />
        <circle cx="16.5" cy="17.5" r="1.5" />
        <path d="M3 15h18" stroke-linecap="round" />
      </svg>
    ) : name === 'performance' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <circle cx="12" cy="12" r="8.5" />
        <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    ) : name === 'winter' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M12 3v18M3 12h18" stroke-linecap="round" />
        <path d="M6.5 6.5l11 11M17.5 6.5l-11 11" stroke-linecap="round" />
      </svg>
    ) : name === 'ev' ? (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M13 2L6 13h5l-1 9 8-12h-5l0-8z" stroke-linejoin="round" />
      </svg>
    ) : null
  }
</span>
