---
import { buildPopularTireSizeCards } from '../../lib/home-sections';

const sizes = buildPopularTireSizeCards();
---

<section class="home-section home-section--alt home-popular-sizes" aria-labelledby="home-popular-sizes-title">
  <div class="home-popular-sizes__panel">
    <header class="home-popular-sizes__header">
      <div class="home-popular-sizes__intro">
        <h2 id="home-popular-sizes-title" class="home-popular-sizes__title">Popular Tire Sizes</h2>
        <p class="home-popular-sizes__desc">Quick access to the most searched tire sizes.</p>
      </div>
      <a href="/tire-sizes" class="home-popular-sizes__view-all">
        View all tire sizes
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path d="M7 10h8M11 6l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </header>

    <div class="home-popular-sizes__grid">
      {
        sizes.map((item) => (
          <a href={item.href} class="home-popular-sizes__pill">
            <span class="home-popular-sizes__size">{item.size}</span>
            <svg
              class="home-popular-sizes__arrow"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path d="M7 10h8M11 6l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>
