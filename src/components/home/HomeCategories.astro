---
import HomeCategoryIcon from './HomeCategoryIcon.astro';
import HomeSectionHeader from './HomeSectionHeader.astro';
import { HOME_BROWSE_CATEGORIES } from '../../lib/home-sections';
---

<section class="home-section home-section--alt home-reveal home-categories" aria-labelledby="home-categories-title">
  <HomeSectionHeader
    id="home-categories-title"
    title="Browse by Category"
    description="Explore tire sizes grouped by how they're used — category hubs are coming soon."
  />

  <div class="home-categories__grid">
    {
      HOME_BROWSE_CATEGORIES.map((category) => (
        <a href={category.href} class="home-categories__card hub-link-card">
          <span class="home-categories__icon-wrap">
            <HomeCategoryIcon name={category.icon} />
          </span>
          <span class="home-categories__body">
            <h3 class="home-categories__title">{category.title}</h3>
            <p class="home-categories__desc">{category.description}</p>
          </span>
          <span class="home-categories__arrow" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M7 10h8M11 6l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))
    }
  </div>
</section>
