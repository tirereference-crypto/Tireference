---
import HomeSectionHeader from './HomeSectionHeader.astro';
import HomeTrustIcon from './HomeTrustIcon.astro';
import { HOME_TRUST_CARDS } from '../../lib/home-sections';
---

<section class="home-section home-section--alt home-reveal home-why" aria-labelledby="home-why-title">
  <HomeSectionHeader
    id="home-why-title"
    title="Why Tire Reference"
    description="Built for owners who want accurate numbers, real fitment context, and tools that respect their time."
  />

  <div class="home-why__grid">
    {
      HOME_TRUST_CARDS.map((card) => (
        <article class="home-why__card hub-link-card">
          <span class="home-why__icon-wrap">
            <HomeTrustIcon name={card.icon} />
          </span>
          <h3 class="home-why__title">{card.title}</h3>
          <p class="home-why__desc">{card.description}</p>
        </article>
      ))
    }
  </div>
</section>
