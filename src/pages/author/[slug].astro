---
import Layout from '../../layouts/Layout.astro';
import PersonCard from '../../components/trust/PersonCard.astro';
import {
  buildPersonSchema,
  getAllPeople,
  getPersonBySlug,
  getPersonCreditGroups,
  personProfilePath,
} from '../../lib/people';
import { buildPageSchema } from '../../lib/seo/page-schemas';
import { SITE_CONTENT_UPDATED, formatEditorialDate } from '../../lib/editorial';
import '../../styles/info-pages.css';

export function getStaticPaths() {
  return getAllPeople().map((person) => ({
    params: { slug: person.slug },
    props: { person },
  }));
}

const slug = Astro.params.slug!;
const person = Astro.props.person ?? getPersonBySlug(slug);
if (!person) throw new Error(`Unknown author slug: ${slug}`);

const pagePath = personProfilePath(person.slug);
const creditGroups = getPersonCreditGroups(person);
const title = `${person.name} — ${person.role}`;
const description = `${person.name} (${person.role}) on Tire Reference. ${person.bio.slice(0, 140).trim()}…`;

const personSchema = buildPersonSchema(person);
const schema = buildPageSchema({
  breadcrumbs: [
    { name: 'Home', item: '/' },
    { name: 'About', item: '/about/' },
    { name: person.name, item: pagePath },
  ],
  extra: [personSchema],
});

const sameAs = [person.links?.linkedin, person.links?.website, person.links?.x].filter(Boolean);
---

<Layout title={title} description={description} canonical={pagePath} schema={schema}>
  <div class="info-page">
    <div class="info-shell info-shell--narrow">
      <header class="author-profile">
        <div class="author-profile__header">
          {
            person.photo ? (
              <img
                src={person.photo}
                alt=""
                class="author-profile__photo"
                width="128"
                height="128"
                loading="eager"
                decoding="async"
              />
            ) : null
          }
          <div class="author-profile__intro">
            <p class="author-profile__eyebrow">Author profile</p>
            <h1 class="author-profile__name">{person.name}</h1>
            <p class="author-profile__role">{person.role}</p>
            {
              sameAs.length > 0 ? (
                <ul class="author-profile__links">
                  {
                    person.links?.website ? (
                      <li><a href={person.links.website} rel="me noopener noreferrer" target="_blank">Website</a></li>
                    ) : null
                  }
                  {
                    person.links?.linkedin ? (
                      <li><a href={person.links.linkedin} rel="me noopener noreferrer" target="_blank">LinkedIn</a></li>
                    ) : null
                  }
                  {
                    person.links?.x ? (
                      <li><a href={person.links.x} rel="me noopener noreferrer" target="_blank">X</a></li>
                    ) : null
                  }
                </ul>
              ) : null
            }
          </div>
        </div>

        <div class="author-profile__bio info-section__body">
          <p>{person.bio}</p>
        </div>

        {
          person.credentials.length > 0 ? (
            <section class="author-profile__credentials" aria-labelledby="author-credentials-title">
              <h2 id="author-credentials-title" class="info-section__title">Credentials & experience</h2>
              <ul class="info-pill-list">
                {person.credentials.map((item) => (
                  <li class="info-pill-list__item">{item}</li>
                ))}
              </ul>
            </section>
          ) : null
        }
      </header>

      <section class="info-section" aria-labelledby="author-credits-title">
        <h2 id="author-credits-title" class="info-section__title">Content on Tire Reference</h2>
        <p class="info-section__body">
          {person.name} is credited on the following sections of Tire Reference. Content last reviewed {formatEditorialDate(SITE_CONTENT_UPDATED)}.
        </p>

        <div class="author-credits">
          {
            creditGroups.map((group) => (
              <article class="author-credit-card">
                <div class="author-credit-card__head">
                  <h3 class="author-credit-card__title">{group.title}</h3>
                  <span class="author-credit-card__count">{group.count} pages</span>
                </div>
                <p class="author-credit-card__desc">{group.description}</p>
                <ul class="author-credit-card__samples">
                  {group.samples.map((sample) => (
                    <li><a href={sample.href}>{sample.label}</a></li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="info-section" aria-labelledby="author-team-title">
        <h2 id="author-team-title" class="info-section__title">Editorial team</h2>
        <div class="person-card-grid">
          {
            getAllPeople()
              .filter((member) => member.slug !== person.slug)
              .map((member) => <PersonCard person={member} />)
          }
        </div>
      </section>
    </div>
  </div>
</Layout>
