---
import Layout from '../layouts/Layout.astro';
import InfoPageHero from '../components/info/InfoPageHero.astro';
import { CONTACT_EMAIL } from '../lib/info-pages';
import { buildInfoPageSchema } from '../lib/seo/info-page-schema';
import { formatEditorialDate } from '../lib/editorial';
import '../styles/info-pages.css';

const title = 'Privacy Policy';
const description =
  'Read the Tire Reference privacy policy to understand what information we collect, how we use it, the cookies we set, and the choices you have over your data.';

const schema = buildInfoPageSchema(title, description, '/privacy-policy', 'Privacy Policy');
const updated = formatEditorialDate();
---

<Layout title={title} description={description} canonical="/privacy-policy" schema={schema}>
  <div class="info-page">
    <div class="info-shell info-shell--narrow">
      <InfoPageHero
        title="Privacy Policy"
        lead="This policy explains what information Tire Reference may collect when you use our website, how we use it, and the choices available to you."
      />

      <article class="info-legal">
        <h2>Information we collect</h2>
        <p>
          Tire Reference is designed to work without creating an account. We may collect limited technical information when you visit the site, such as browser type, device category, approximate region, pages viewed, and referral source. If you contact us, we collect the information you choose to provide — for example your name, email address, subject line, and message content.
        </p>
        <p>
          Calculator inputs are processed to deliver results in your browser session. We do not require you to submit vehicle ownership details, VINs, or purchase history to use our tools.
        </p>

        <h2>Cookies</h2>
        <p>
          Cookies and similar technologies help Tire Reference remember preferences, keep the site secure, and understand how visitors use our pages. Some cookies are essential for basic site functionality. Others help us measure performance and improve the experience over time.
        </p>
        <p>
          You can control cookies through your browser settings. Disabling certain cookies may affect how some features behave.
        </p>

        <h2>Analytics</h2>
        <p>
          We may use analytics services such as Google Analytics to understand aggregate traffic patterns — for example which calculators are most helpful and where visitors encounter errors. Analytics data is generally reported in summarized form and is used to improve content, performance, and usability.
        </p>
        <p>
          Google Analytics may set its own cookies and process usage data according to Google&apos;s policies. You can learn more about Google&apos;s practices and opt-out tools through Google&apos;s documentation.
        </p>

        <h2>Advertising</h2>
        <p>
          Tire Reference may display advertising in the future to support free access to calculators and guides. If advertising partners are used, they may employ cookies or similar technologies to deliver and measure ads, subject to their own privacy policies and any consent controls we implement.
        </p>

        <h2>Third-party services</h2>
        <p>
          We rely on trusted infrastructure and service providers to host the site, deliver fonts, measure performance, and process contact requests when those features are enabled. These providers process data only as needed to perform services on our behalf and are expected to protect it appropriately.
        </p>
        <p>
          Tire Reference may link to external websites — for example manufacturer documentation or retailer pages. We are not responsible for the privacy practices of third-party sites and encourage you to review their policies separately.
        </p>

        <h2>How information is used</h2>
        <p>We use collected information to:</p>
        <ul>
          <li>Operate, maintain, and secure Tire Reference</li>
          <li>Respond to questions, feedback, and support requests</li>
          <li>Improve calculators, content, and site performance</li>
          <li>Detect abuse, fraud, or technical issues</li>
          <li>Comply with applicable legal obligations</li>
        </ul>
        <p>
          We do not sell your personal information.
        </p>

        <h2>Your rights</h2>
        <p>
          Depending on where you live, you may have rights to access, correct, delete, or restrict certain processing of your personal information. You may also have the right to object to particular uses or to withdraw consent where processing is consent-based.
        </p>
        <p>
          To exercise these rights or ask questions about your data, contact us using the details below. We will respond within a reasonable timeframe.
        </p>

        <h2>Data security</h2>
        <p>
          We implement reasonable administrative, technical, and organizational measures designed to protect information against unauthorized access, alteration, disclosure, or destruction. No method of transmission over the internet is completely secure, and we cannot guarantee absolute security.
        </p>

        <h2>Contact</h2>
        <p>
          For privacy-related questions or requests, email <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a> or visit our <a href="/contact">contact page</a>.
        </p>
      </article>

      <p class="info-updated">Last updated: {updated}</p>
    </div>
  </div>
</Layout>
