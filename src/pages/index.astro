---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import HomeHeroTrust from '../components/home/HomeHeroTrust.astro';
import HomeQuickActions from '../components/home/HomeQuickActions.astro';
import HomeFeaturedComparison from '../components/home/HomeFeaturedComparison.astro';
import HomeCategories from '../components/home/HomeCategories.astro';
import HomeExploreTrust from '../components/home/HomeExploreTrust.astro';
import HomePopularLinks from '../components/home/HomePopularLinks.astro';
import HomeSeoContent from '../components/home/HomeSeoContent.astro';
import HomeScrollReveal from '../components/home/HomeScrollReveal.astro';
import {
  buildHomePageSchema,
  SEO_DESCRIPTIONS,
  SEO_TITLES,
} from '../lib/seo';
import '../styles/home.css';

const schema = buildHomePageSchema();
---

<Layout
  title={SEO_TITLES.homepage}
  description={SEO_DESCRIPTIONS.homepage}
  canonical="/"
  schema={schema}
  preloadHero={true}
  mainClass="bg-surface"
>
  <div class="home-page">
    <div class="home-shell">
      {/* Mobile order: Hero → Trust micro-row → Calculators → … */}
      <div class="home-hero-stack">
        <HomeHero />
        <HomeHeroTrust />
        <HomeQuickActions />
      </div>

      <div class="home-sections">
        <HomeFeaturedComparison />
        <HomeCategories />
        <HomeExploreTrust />
        <HomePopularLinks />
        <HomeSeoContent />
      </div>
    </div>
  </div>

  <HomeScrollReveal />
</Layout>
