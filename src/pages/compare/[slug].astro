---
import Layout from '../../layouts/Layout.astro';
import PremiumTireSizeComparison from '../../components/calculators/PremiumTireSizeComparison';
import { buildComparisonInsights } from '../../lib/tire-comparison-insights';
import { getAllComparisonSlugs } from '../../lib/tire-comparison-links';
import {
  canonicalComparisonPath,
  comparisonSlugFromSizes,
  formatComparisonTireSize,
  parseComparisonSlug,
} from '../../lib/comparison-url';
import { buildComparisonSeoBundle } from '../../lib/comparison-seo';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import {
  buildPageSchema,
  comparisonBreadcrumbs,
} from '../../lib/seo/page-schemas';
import { buildEditorialArticleSchema } from '../../lib/seo/editorial-schema';
import { SITE_CONTENT_UPDATED } from '../../lib/editorial';
import { prebuiltCompareOgImageUrl } from '../../lib/og/og-image-url';
import { compareTires, getTireSpecs } from '../../lib/tire-math';

export function getStaticPaths() {
  return getAllComparisonSlugs().map(({ slug, current, new: newSize }) => ({
    params: { slug },
    props: { current, newSize },
  }));
}

const { slug } = Astro.params;
const props = Astro.props as { current?: string; newSize?: string };
const parsed = slug ? parseComparisonSlug(slug) : null;
const current = props.current ?? parsed?.canonical.current;
const newSize = props.newSize ?? parsed?.canonical.new;

if (!current || !newSize) {
  throw new Error(`Unknown comparison slug: ${slug}`);
}

const displayCurrent = formatComparisonTireSize(current) ?? current;
const displayNew = formatComparisonTireSize(newSize) ?? newSize;

let title = `${displayCurrent} vs ${displayNew} Tire Size Comparison`;
let description = SEO_DESCRIPTIONS.comparison;
let pageHeading = title;
let pageAnswer: string | undefined;
let faqs: { question: string; answer: string }[] = [];

try {
  const specsA = getTireSpecs(current);
  const specsB = getTireSpecs(newSize);
  const comparison = compareTires(current, newSize, 60);
  const seo = buildComparisonSeoBundle(current, newSize, comparison, specsA, specsB);
  const insights = buildComparisonInsights(current, newSize, comparison, specsA, specsB);
  title = seo.title;
  description = seo.metaDescription;
  pageHeading = seo.h1;
  pageAnswer = seo.answer;
  faqs = insights.seo.faqs;
} catch {
  /* keep defaults for invalid pairs filtered at build time */
}

const canonicalSlug = comparisonSlugFromSizes(current, newSize);
const canonical = canonicalComparisonPath(current, newSize);

const ogImage = prebuiltCompareOgImageUrl(canonicalSlug);

const schema = buildPageSchema({
  breadcrumbs: comparisonBreadcrumbs(current, newSize),
  faqs,
  extra: [
    buildEditorialArticleSchema({
      headline: title,
      description,
      url: canonical,
      dateModified: SITE_CONTENT_UPDATED,
    }),
  ],
});
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  image={ogImage}
  schema={schema}
>
  <PremiumTireSizeComparison
    client:load
    initialCurrent={current}
    initialNew={newSize}
    pageHeading={pageHeading}
    pageAnswer={pageAnswer}
    showCalculatorHeading
  />
</Layout>
