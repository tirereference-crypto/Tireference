---
import Layout from '../../layouts/Layout.astro';
import PremiumTireSizeComparison from '../../components/calculators/PremiumTireSizeComparison';
import { buildComparisonInsights } from '../../lib/tire-comparison-insights';
import { prebuiltCompareOgImageUrl } from '../../lib/og/og-image-url';
import { comparisonSlugFromSizes } from '../../lib/comparison-url';
import { parseTireComparisonFromSearch } from '../../lib/calculator-url-state';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildPageSchema, calculatorBreadcrumbs } from '../../lib/seo/page-schemas';
import { buildWebApplicationSchema } from '../../lib/seo/schema';
import { CALCULATION_LOGIC_UPDATED } from '../../lib/eeat-metadata';
import { compareTires, getTireSpecs } from '../../lib/tire-math';

const { from: current, to: newSize, third } = parseTireComparisonFromSearch(Astro.url.searchParams, {
  from: '225/45R17',
  to: '235/40R18',
});

// The indexed landing page (canonical /calculators/tire-comparison-calculator/) always uses
// tool-focused metadata. Pair-specific titles/descriptions live on the
// dedicated /compare/[slug] pages, not here.
const title = 'Tire Size Comparison Calculator';
const description = SEO_DESCRIPTIONS.comparison;
let faqs: { question: string; answer: string }[] = [];

try {
  const specsA = getTireSpecs(current);
  const specsB = getTireSpecs(newSize);
  const comparison = compareTires(current, newSize, 60);
  const insights = buildComparisonInsights(current, newSize, comparison, specsA, specsB);
  faqs = insights.seo.faqs;
} catch {
  /* keep defaults for invalid query params */
}

const ogImage = prebuiltCompareOgImageUrl(comparisonSlugFromSizes(current, newSize));

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Tire Size Comparison'),
  faqs,
  extra: [
    buildWebApplicationSchema({
      name: title,
      description,
      url: '/calculators/tire-comparison-calculator/',
      dateModified: CALCULATION_LOGIC_UPDATED,
      id: 'tire-comparison-calculator',
    }),
  ],
});
---

<Layout
  title={title}
  description={description}
  canonical="/calculators/tire-comparison-calculator/"
  image={ogImage}
  schema={schema}
>
  <PremiumTireSizeComparison
    client:load
    initialCurrent={current}
    initialNew={newSize}
    initialThird={third}
  />
</Layout>
