---
import Layout from '../../layouts/Layout.astro';
import PremiumWheelOffsetCalculator from '../../components/calculators/PremiumWheelOffsetCalculator';
import { OFFSET_FAQS } from '../../lib/wheel-offset-insights';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildPageSchema, calculatorBreadcrumbs } from '../../lib/seo/page-schemas';
import TrustDisclosure from '../../components/trust/TrustDisclosure.astro';

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Wheel Offset Calculator'),
  faqs: OFFSET_FAQS.map((faq) => ({ question: faq.question, answer: faq.answer })),
});
---

<Layout
  title="Wheel Offset & Backspacing Calculator"
  description={SEO_DESCRIPTIONS.wheelOffsetCalculator}
  canonical="/calculators/wheel-offset-calculator/"
  schema={schema}
>
  <PremiumWheelOffsetCalculator client:load />
  <div class="tl-container pb-10 lg:pb-14">
    <TrustDisclosure
      title="How our calculators work"
      subtitle="Offset, backspacing, and clearance use standard wheel-geometry formulas independent of tire diameter math — methodology and sources below."
    />
  </div>
</Layout>
