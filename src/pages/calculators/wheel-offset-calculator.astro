---
import Layout from '../../layouts/Layout.astro';
import PremiumWheelOffsetCalculator from '../../components/calculators/PremiumWheelOffsetCalculator';
import { parseWheelOffsetFromSearch } from '../../lib/calculator-url-state';
import { OFFSET_FAQS } from '../../lib/wheel-offset-insights';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildPageSchema, calculatorBreadcrumbs } from '../../lib/seo/page-schemas';
import { buildWebApplicationSchema } from '../../lib/seo/schema';
import { CALCULATION_LOGIC_UPDATED } from '../../lib/eeat-metadata';

const { current: initialCurrent, new: initialNew } = parseWheelOffsetFromSearch(
  Astro.url.searchParams,
  {
    current: { widthIn: '8', diameterIn: '18', offsetMm: '35' },
    new: { widthIn: '9', diameterIn: '18', offsetMm: '20' },
  },
);

const title = 'Wheel Offset & Backspacing Calculator';
const description = SEO_DESCRIPTIONS.wheelOffsetCalculator;

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Wheel Offset Calculator'),
  faqs: OFFSET_FAQS.map((faq) => ({ question: faq.question, answer: faq.answer })),
  extra: [
    buildWebApplicationSchema({
      name: title,
      description,
      url: '/calculators/wheel-offset-calculator/',
      dateModified: CALCULATION_LOGIC_UPDATED,
      id: 'wheel-offset-calculator',
    }),
  ],
});
---

<Layout
  title={title}
  description={description}
  canonical="/calculators/wheel-offset-calculator/"
  schema={schema}
>
  <PremiumWheelOffsetCalculator
    client:load
    initialCurrent={initialCurrent}
    initialNew={initialNew}
  />
</Layout>
