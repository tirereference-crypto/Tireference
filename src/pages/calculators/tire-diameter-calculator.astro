---
import Layout from '../../layouts/Layout.astro';
import PremiumTireDiameterCalculator from '../../components/calculators/PremiumTireDiameterCalculator';
import { parseTireDiameterFromSearch } from '../../lib/calculator-url-state';
import {
  buildDiameterFaqs,
  DIAMETER_FAQ_PRIMARY_COUNT,
} from '../../lib/tire-diameter-insights';
import { searchTiresByDiameter, WHEEL_DIAMETER_OPTIONS } from '../../lib/tire-diameter-search';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildPageSchema, calculatorBreadcrumbs } from '../../lib/seo/page-schemas';
import { buildWebApplicationSchema } from '../../lib/seo/schema';
import { CALCULATION_LOGIC_UPDATED } from '../../lib/eeat-metadata';

const parsed = parseTireDiameterFromSearch(Astro.url.searchParams, {
  diameter: 33,
  rim: 18,
});
const initialDiameter = parsed.diameter;
const initialWheel = parsed.rim;

const schemaWheel =
  initialWheel === 'any'
    ? 18
    : ((WHEEL_DIAMETER_OPTIONS as readonly number[]).includes(Number(initialWheel))
        ? (Number(initialWheel) as (typeof WHEEL_DIAMETER_OPTIONS)[number])
        : 18);

const initialSearch =
  initialWheel === 'any'
    ? null
    : searchTiresByDiameter({
        targetDiameterIn: initialDiameter,
        wheelDiameterIn: schemaWheel,
        toleranceIn: 1,
      });

const schemaFaqs = buildDiameterFaqs({
  targetDiameterIn: initialDiameter,
  wheelDiameterIn: initialWheel === 'any' ? 'any' : schemaWheel,
  closestSize: initialSearch?.matches[0]?.size ?? null,
  closestDiameterIn: initialSearch?.matches[0]?.diameterIn ?? null,
  toleranceIn: 1,
}).slice(0, DIAMETER_FAQ_PRIMARY_COUNT);

const title = 'Tire Diameter Calculator';
const description = SEO_DESCRIPTIONS.diameterCalculator;

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Tire Diameter Calculator'),
  faqs: schemaFaqs.map((faq) => ({ question: faq.question, answer: faq.answer })),
  extra: [
    buildWebApplicationSchema({
      name: title,
      description,
      url: '/calculators/tire-diameter-calculator/',
      dateModified: CALCULATION_LOGIC_UPDATED,
      id: 'tire-diameter-calculator',
    }),
  ],
});
---

<Layout
  title={title}
  description={description}
  canonical="/calculators/tire-diameter-calculator/"
  schema={schema}
>
  <PremiumTireDiameterCalculator
    client:load
    initialDiameter={initialDiameter}
    initialWheel={initialWheel}
  />
</Layout>
