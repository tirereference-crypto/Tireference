---
import Layout from '../../layouts/Layout.astro';
import PremiumTireSizeCalculator from '../../components/calculators/PremiumTireSizeCalculator';
import HubBreadcrumb from '../../components/hub/HubBreadcrumb.astro';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import {
  buildPageSchema,
  calculatorBreadcrumbs,
} from '../../lib/seo/page-schemas';
import { buildWebApplicationSchema } from '../../lib/seo/schema';
import { CALCULATION_LOGIC_UPDATED } from '../../lib/eeat-metadata';
import { getVisibleTireSizeCalculatorFaqs } from '../../lib/tire-size-calculator-faqs';

const size = Astro.url.searchParams.get('size') ?? undefined;

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Tire Size Calculator'),
  faqs: [...getVisibleTireSizeCalculatorFaqs()],
  extra: [
    buildWebApplicationSchema({
      name: 'Tire Size Calculator',
      description: SEO_DESCRIPTIONS.tireSizeCalculator,
      url: '/calculators/tire-size-calculator/',
      dateModified: CALCULATION_LOGIC_UPDATED,
      id: 'tire-size-calculator',
    }),
  ],
});
---

<Layout
  title="Tire Size Calculator – Specs & Diameter"
  description={SEO_DESCRIPTIONS.tireSizeCalculator}
  canonical="/calculators/tire-size-calculator/"
  schema={schema}
>
  <div class="tl-container py-5 lg:py-6">
    <HubBreadcrumb
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Tire Size Calculator' },
      ]}
    />
    <PremiumTireSizeCalculator client:load initialSize={size} />
  </div>
</Layout>
