---
import Layout from '../../layouts/Layout.astro';
import PremiumGearRatioCalculator from '../../components/calculators/PremiumGearRatioCalculator';
import { parseGearRatioFromSearch } from '../../lib/calculator-url-state';
import { GEAR_FAQS } from '../../lib/gear-ratio-insights';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildPageSchema, calculatorBreadcrumbs } from '../../lib/seo/page-schemas';

const initialFields = parseGearRatioFromSearch(Astro.url.searchParams);

const schema = buildPageSchema({
  breadcrumbs: calculatorBreadcrumbs('Gear Ratio Calculator'),
  faqs: GEAR_FAQS.map((faq) => ({ question: faq.question, answer: faq.answer })),
});
---

<Layout
  title="Gear Ratio Calculator – Tire Size & RPM"
  description={SEO_DESCRIPTIONS.gearRatioCalculator}
  canonical="/calculators/gear-ratio-calculator/"
  schema={schema}
>
  <PremiumGearRatioCalculator client:load initialFields={initialFields} />
</Layout>
