---
import Layout from '../../layouts/Layout.astro';
import TireSizeGuide from '../../components/hub/premium/TireSizeGuide.astro';
import { TIRE_SIZES } from '../../data/tire-sizes';
import { buildTireSizeHubData } from '../../lib/tire-size-hub';
import { hubPagePath, sizeToSlug, slugToSize } from '../../lib/tire-size-url';
import { SEO_DESCRIPTIONS } from '../../lib/seo/constants';
import { buildTireSizeHubPageTitle } from '../../lib/seo/format';
import {
  buildArticleSchema,
} from '../../lib/seo/schema';
import {
  buildPageSchema,
  hubBreadcrumbs,
} from '../../lib/seo/page-schemas';
import { SITE_CONTENT_UPDATED } from '../../lib/editorial';
import { prebuiltTireOgImageUrl } from '../../lib/og/og-image-url';
import { buildTireSizeGuideData } from '../../lib/tire-size-guide';
import {
  TIRE_CATEGORY_HUBS,
  getPrimaryTireSizeHubCategory,
  tireCategoryHubPath,
} from '../../lib/tire-category-hubs';

export function getStaticPaths() {
  return TIRE_SIZES.map((entry) => ({
    params: { size: sizeToSlug(entry.size) },
    props: { entry },
  }));
}

const { size: slug } = Astro.params;
const size = slugToSize(slug!);
const hub = size ? buildTireSizeHubData(size) : null;
if (!hub) throw new Error(`Unknown tire size slug: ${slug}`);

const guide = buildTireSizeGuideData(hub);
const pageFaqs = guide.faq;

const { displaySize, specs } = hub;
const pagePath = hubPagePath(hub.entry.size);
const primaryCategory = getPrimaryTireSizeHubCategory(hub.entry);

const metaDescription = `${displaySize} tire size: ${specs.overallDiameterIn.toFixed(2)} in overall diameter, ${specs.sectionWidthIn.toFixed(2)} in width, ${specs.sidewallIn.toFixed(2)} in sidewall, ${Math.round(specs.revsPerMile)} revs/mile. Compare equivalents, fitment & alternatives.`;

const pageTitle = buildTireSizeHubPageTitle(displaySize);

const ratingProperties: Array<Record<string, unknown>> = [];
if (hub.ratings) {
  if (hub.ratings.loadIndex) {
    ratingProperties.push({ '@type': 'PropertyValue', name: 'Load Index', value: hub.ratings.loadIndex });
  }
  if (hub.ratings.speedRating) {
    ratingProperties.push({ '@type': 'PropertyValue', name: 'Speed Rating', value: hub.ratings.speedRating });
  }
  if (hub.ratings.loadRange) {
    ratingProperties.push({ '@type': 'PropertyValue', name: 'Load Range', value: hub.ratings.loadRange });
  }
  if (hub.ratings.maxLoadKg != null) {
    ratingProperties.push({
      '@type': 'PropertyValue',
      name: 'Maximum Load',
      value: hub.ratings.maxLoadKg,
      unitCode: 'KGM',
      unitText: 'kg',
    });
  }
}

const schema = buildPageSchema({
  breadcrumbs: hubBreadcrumbs(displaySize, pagePath, {
    name: TIRE_CATEGORY_HUBS[primaryCategory].label,
    item: tireCategoryHubPath(primaryCategory),
  }),
  faqs: pageFaqs,
  extra: [
    buildArticleSchema({
      headline: `${displaySize} Tire Size — Diameter, Specs & Fitment`,
      description: metaDescription,
      url: pagePath,
      datePublished: SITE_CONTENT_UPDATED,
      dateModified: SITE_CONTENT_UPDATED,
      type: 'TechArticle',
      additionalProperty: ratingProperties,
    }),
  ],
});
const ogImage = prebuiltTireOgImageUrl(slug!);
---

<Layout
  title={pageTitle}
  description={metaDescription || SEO_DESCRIPTIONS.hub}
  canonical={pagePath}
  type="article"
  image={ogImage}
  schema={schema}
>
  <div class="tl-container py-6 lg:py-10">
    <TireSizeGuide hub={hub} />
  </div>
</Layout>
