{
  "name": "tire-logic",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "og:generate": "tsx scripts/generate-og-images.ts",
    "data:master-tires": "python3 scripts/generate-master-tire-data.py",
    "data:comparison-slugs": "tsx scripts/generate-comparison-slugs.ts",
    "validate:generated-pages": "node --max-old-space-size=8192 node_modules/tsx/dist/cli.mjs scripts/validate-generated-pages.ts",
    "validate:internal-links": "tsx scripts/validate-internal-links.ts",
    "validate:metadata": "VALIDATE_DIST=1 vitest run src/lib/seo/page-metadata-schema.test.ts",
    "validate:production": "node --max-old-space-size=8192 node_modules/tsx/dist/cli.mjs scripts/validate-production.ts",
    "validate:public-output": "node --max-old-space-size=8192 node_modules/tsx/dist/cli.mjs scripts/validate-public-output.ts",
    "build": "npm run data:comparison-slugs && npm run og:generate && node --max-old-space-size=2048 node_modules/astro/bin/astro.mjs build && npm run validate:production && npm run validate:public-output",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vercel/og": "^0.11.1",
    "astro": "^6.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "tsx": "^4.23.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
